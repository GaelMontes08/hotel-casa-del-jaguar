---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = useTranslations(locale);

const images = [
  { src: '/images/sala.webp',                      hd: '/images/HD/sala.jpg',                      altEs: 'Sala común',             altEn: 'Common lounge'    },
  { src: '/images/sala1.webp',                     hd: '/images/HD/sala1.jpg',                     altEs: 'Sala común',             altEn: 'Common lounge'    },
  { src: '/images/sala2.webp',                     hd: '/images/HD/sala2.jpg',                     altEs: 'Sala común',             altEn: 'Common lounge'    },
  { src: '/images/patio.webp',                     hd: '/images/HD/patio.jpg',                     altEs: 'Patio exterior',         altEn: 'Outdoor patio'    },
  { src: '/images/patio1.webp',                    hd: '/images/HD/patio1.jpg',                    altEs: 'Patio exterior',         altEn: 'Outdoor patio'    },
  { src: '/images/patio2.webp',                    hd: '/images/HD/patio2.jpg',                    altEs: 'Patio exterior',         altEn: 'Outdoor patio'    },
  { src: '/images/patio3.webp',                    hd: '/images/HD/patio3.jpg',                    altEs: 'Patio exterior',         altEn: 'Outdoor patio'    },
  { src: '/images/cocina.webp',                    hd: '/images/HD/cocina.jpg',                    altEs: 'Cocina y comedor',       altEn: 'Kitchen & dining' },
  { src: '/images/cocina1.webp',                   hd: '/images/HD/cocina1.jpg',                   altEs: 'Cocina y comedor',       altEn: 'Kitchen & dining' },
  { src: '/images/cocina2.webp',                   hd: '/images/HD/cocina2.jpg',                   altEs: 'Cocina y comedor',       altEn: 'Kitchen & dining' },
  { src: '/images/cocina3.webp',                   hd: '/images/HD/cocina3.jpg',                   altEs: 'Cocina y comedor',       altEn: 'Kitchen & dining' },
  { src: '/images/habitación-simple-doble.webp',   hd: '/images/HD/habitación-simple-doble.jpg',   altEs: 'Habitación simple/doble', altEn: 'Single/double room' },
  { src: '/images/habitación-simple-doble1.webp',  hd: '/images/HD/habitación-simple-doble1.jpg',  altEs: 'Habitación simple/doble', altEn: 'Single/double room' },
  { src: '/images/habitación-simple-doble2.webp',  hd: '/images/HD/habitación-simple-doble2.jpg',  altEs: 'Habitación simple/doble', altEn: 'Single/double room' },
  { src: '/images/habitación-simple-doble3.webp',  hd: '/images/HD/habitación-simple-doble3.jpg',  altEs: 'Habitación simple/doble', altEn: 'Single/double room' },
  { src: '/images/habitación-simple-doble4.webp',  hd: '/images/HD/habitación-simple-doble4.jpg',  altEs: 'Habitación simple/doble', altEn: 'Single/double room' },
  { src: '/images/maloca.webp',                    hd: '/images/HD/maloca.jpg',                    altEs: 'Maloca',                 altEn: 'Maloca'           },
  { src: '/images/maloca1.webp',                   hd: '/images/HD/maloca1.jpg',                   altEs: 'Maloca',                 altEn: 'Maloca'           },
];
---

<Layout locale={locale} title={t.gallery.title} canonicalPath={path}>
  <!-- Page header -->
  <section class="relative h-56 flex items-center justify-center bg-jungle-900 overflow-hidden">
    <div class="text-center text-white">
      <h1 class="font-heading text-4xl font-bold">{t.gallery.title}</h1>
      <p class="mt-2 text-jungle-300">{t.gallery.subtitle}</p>
    </div>
  </section>

  <!-- Masonry grid -->
  <section class="py-12 px-4 bg-stone-50">
    <div class="max-w-7xl mx-auto columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
      {images.map((img, i) => {
        const alt = locale === 'es' ? img.altEs : img.altEn;
        return (
          <button
            type="button"
            class="lb-trigger break-inside-avoid block w-full overflow-hidden rounded-2xl bg-stone-200 cursor-zoom-in group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-jaguar-400"
            data-index={String(i)}
            data-hd={img.hd}
            data-alt={alt}
            aria-label={`${locale === 'es' ? 'Ver foto ampliada' : 'View full photo'}: ${alt}`}
          >
            <img
              src={img.src}
              alt={alt}
              class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500 pointer-events-none"
              loading={i < 6 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </button>
        );
      })}
    </div>
  </section>

  <!-- ── Lightbox ── -->
  <div
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label={locale === 'es' ? 'Visor de imágenes' : 'Image viewer'}
    class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 backdrop-blur-sm"
    tabindex="-1"
  >
    <!-- Close -->
    <button
      id="lb-close"
      type="button"
      aria-label={locale === 'es' ? 'Cerrar visor' : 'Close viewer'}
      class="absolute top-4 right-4 z-10 p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors"
    >
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Counter -->
    <p id="lb-counter" class="absolute top-5 left-5 text-white/40 text-xs tabular-nums select-none pointer-events-none"></p>

    <!-- Prev -->
    <button
      id="lb-prev"
      type="button"
      aria-label={locale === 'es' ? 'Foto anterior' : 'Previous photo'}
      class="absolute left-2 sm:left-4 top-1/2 -translate-y-1/2 p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <!-- Image area -->
    <div class="flex items-center justify-center w-full h-full px-16 sm:px-24 py-14 select-none" id="lb-backdrop">
      <!-- Spinner (shown while HD image loads) -->
      <div id="lb-spinner" class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-10 h-10 rounded-full border-2 border-white/20 border-t-white animate-spin"></div>
      </div>
      <!-- HD image — src is intentionally empty until user opens a photo -->
      <img
        id="lb-img"
        src=""
        alt=""
        class="max-w-full max-h-full object-contain rounded-lg shadow-2xl opacity-0 transition-opacity duration-300"
      />
    </div>

    <!-- Next -->
    <button
      id="lb-next"
      type="button"
      aria-label={locale === 'es' ? 'Siguiente foto' : 'Next photo'}
      class="absolute right-2 sm:right-4 top-1/2 -translate-y-1/2 p-2 rounded-full text-white/70 hover:text-white hover:bg-white/10 transition-colors"
    >
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Caption -->
    <p id="lb-caption" class="absolute bottom-4 inset-x-0 text-center text-white/50 text-sm pointer-events-none px-8 truncate"></p>
  </div>
</Layout>

<script>
  const overlay   = document.getElementById('lightbox')  as HTMLDivElement;
  const lbImg     = document.getElementById('lb-img')    as HTMLImageElement;
  const lbSpinner = document.getElementById('lb-spinner') as HTMLDivElement;
  const lbCaption = document.getElementById('lb-caption') as HTMLParagraphElement;
  const lbCounter = document.getElementById('lb-counter') as HTMLParagraphElement;
  const triggers  = Array.from(document.querySelectorAll<HTMLButtonElement>('.lb-trigger'));

  let currentIndex = 0;
  // Cache of already-loaded HD srcs so re-opening is instant
  const loaded = new Set<string>();

  function open(index: number) {
    currentIndex = index;
    loadImage(index);
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
    overlay.focus();
  }

  function close() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    document.body.style.overflow = '';
    lbImg.classList.add('opacity-0');
  }

  function navigate(direction: 1 | -1) {
    currentIndex = (currentIndex + direction + triggers.length) % triggers.length;
    loadImage(currentIndex);
  }

  function loadImage(index: number) {
    const btn   = triggers[index];
    const hdSrc = btn.dataset.hd!;
    const alt   = btn.dataset.alt!;

    lbCaption.textContent = alt;
    lbCounter.textContent = `${index + 1} / ${triggers.length}`;

    if (loaded.has(hdSrc)) {
      // Already cached — show immediately
      lbImg.src = hdSrc;
      lbImg.alt = alt;
      lbSpinner.classList.add('hidden');
      lbImg.classList.remove('opacity-0');
      return;
    }

    // HD image has never been requested — load it now for the first time
    lbImg.classList.add('opacity-0');
    lbSpinner.classList.remove('hidden');

    const img = new Image();
    img.onload = () => {
      loaded.add(hdSrc);
      lbImg.src = hdSrc;
      lbImg.alt = alt;
      lbSpinner.classList.add('hidden');
      lbImg.classList.remove('opacity-0');
    };
    img.onerror = () => {
      lbSpinner.classList.add('hidden');
    };
    img.src = hdSrc; // ← only network request happens here
  }

  // Open on thumbnail click
  triggers.forEach((btn, i) => btn.addEventListener('click', () => open(i)));

  // Controls
  document.getElementById('lb-close')!.addEventListener('click', close);
  document.getElementById('lb-prev')!.addEventListener('click', () => navigate(-1));
  document.getElementById('lb-next')!.addEventListener('click', () => navigate(1));

  // Click on backdrop (not image) → close
  document.getElementById('lb-backdrop')!.addEventListener('click', (e) => {
    if ((e.target as HTMLElement).id === 'lb-backdrop') close();
  });

  // Keyboard navigation
  overlay.addEventListener('keydown', (e) => {
    if (e.key === 'Escape')     close();
    if (e.key === 'ArrowLeft')  navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });
</script>
