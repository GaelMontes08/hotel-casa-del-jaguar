---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import { BOOKING_URL } from '@/i18n/utils';
import type { Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = useTranslations(locale);

const rooms = [
  {
    slug: 'suite-selva',
    nameEs: 'Suite Selva',
    nameEn: 'Jungle Suite',
    descriptionEs: 'Amplia suite con vistas a la vegetación amazónica. Incluye cama king, baño privado con ducha, aire acondicionado y balcón privado.',
    descriptionEn: 'Spacious suite overlooking the Amazon vegetation. Includes king bed, private bathroom with shower, air conditioning, and private balcony.',
    priceUSD: 120,
    image: '/images/habitación-simple-doble.webp',
    amenities: ['King bed', 'AC', 'Private balcony', 'WiFi', 'Mini bar'],
  },
  {
    slug: 'habitacion-amazonas',
    nameEs: 'Habitación Amazonas',
    nameEn: 'Amazonas Room',
    descriptionEs: 'Habitación confortable con decoración natural. Cama doble, baño privado y aire acondicionado.',
    descriptionEn: 'Comfortable room with natural decor. Double bed, private bathroom, and air conditioning.',
    priceUSD: 80,
    image: '/images/habitación-simple-doble1.webp',
    amenities: ['Double bed', 'AC', 'WiFi', 'Private bathroom'],
  },
  {
    slug: 'habitacion-jaguar',
    nameEs: 'Habitación Jaguar',
    nameEn: 'Jaguar Room',
    descriptionEs: 'Habitación estándar con toques artesanales locales. Perfecta para viajeros solos o en pareja.',
    descriptionEn: 'Standard room with local artisan touches. Perfect for solo travelers or couples.',
    priceUSD: 65,
    image: '/images/habitación-simple-doble2.webp',
    amenities: ['Queen bed', 'AC', 'WiFi', 'Fan'],
  },
];
---

<Layout locale={locale} title={t.rooms.title} canonicalPath={path}>
  <!-- Page header -->
  <section class="relative h-56 flex items-center justify-center overflow-hidden bg-jungle-900">
    <div class="text-center text-white">
      <h1 class="font-heading text-4xl font-bold">{t.rooms.title}</h1>
      <p class="mt-2 text-jungle-300">{t.rooms.subtitle}</p>
    </div>
  </section>

  <!-- Rooms -->
  <section class="py-16 px-4 bg-stone-50">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {rooms.map((room) => {
        const name = locale === 'es' ? room.nameEs : room.nameEn;
        const description = locale === 'es' ? room.descriptionEs : room.descriptionEn;
        return (
          <article class="bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-shadow">
            <div class="aspect-[4/3] bg-stone-200 overflow-hidden">
              <img
                src={room.image}
                alt={name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
            <div class="p-6">
              <h2 class="font-heading text-xl font-bold text-stone-800 mb-2">{name}</h2>
              <p class="text-stone-500 text-sm mb-4 leading-relaxed">{description}</p>
              <ul class="flex flex-wrap gap-2 mb-5">
                {room.amenities.map((a) => (
                  <li class="text-xs bg-jungle-50 text-jungle-700 px-2 py-1 rounded-full">{a}</li>
                ))}
              </ul>
              <div class="flex items-center justify-between">
                <p class="font-semibold text-jaguar-600 text-lg">
                  ${room.priceUSD} <span class="text-stone-400 text-sm font-normal">/ {t.rooms.perNight}</span>
                </p>
                <a
                  href={BOOKING_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="px-4 py-2 rounded-full bg-jaguar-600 text-white text-sm font-semibold hover:bg-jaguar-700 transition-colors"
                >
                  {t.nav.booking}
                </a>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</Layout>
