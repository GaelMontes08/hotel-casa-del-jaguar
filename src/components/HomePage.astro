            </div>
          </div>
        </div>

        <!-- Thumbnail row -->
        <div class="ts-reveal flex gap-3" style="--td:220ms">
          {[
            '/images/patio3.webp',
            '/images/sala.webp',
            '/images/maloca.webp',
          ].map((src, i) => (
            <div class={`ts-thumb relative overflow-hidden rounded-2xl flex-1 aspect-[3/2] bg-white/5 cursor-pointer ${i === 0 ? 'ring-2 ring-jaguar-400' : ''}`}>
              <img src={src} alt="" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105" loading="lazy" aria-hidden="true" />
              {i !== 0 && <div class="absolute inset-0 bg-black/40"></div>}
