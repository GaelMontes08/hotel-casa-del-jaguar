        </div>

      </div>

      <!-- ─── RIGHT: image panel (contained, rounded) ─── -->
      <div class="relative flex items-center justify-center p-6 lg:p-10 bg-[#0d1410] min-h-[420px] lg:min-h-0">

        <!-- Contained image with rounded corners -->
        <div class="relative w-full h-full overflow-hidden rounded-3xl shadow-2xl shadow-black/60">
          <div id="ts-img-wrap" class="absolute inset-0 scale-[1.06] will-change-transform">
            <img
              src="/images/habitaci%C3%B3n-simple-doble3.webp"
              alt={t.home.testimonials.imgAlt}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>

        <!-- Floating amenity tags -->
        <div class="absolute top-8 right-6 flex flex-col gap-2 ts-reveal" style="--td:300ms">
          {[
            t.home.testimonials.tag1,
            t.home.testimonials.tag2,
            t.home.testimonials.tag3,
            t.home.testimonials.tag4,
            t.home.testimonials.tag5,
          ].map((tag, i) => (
            <span
              class="self-end inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-full text-[0.65rem] font-medium tracking-wide text-white backdrop-blur-md border border-white/20 shadow-lg"
              style={`background:rgba(10,16,12,${0.55 + i * 0.04});transition-delay:${300 + i * 60}ms`}
            >
              <span class="w-2.5 h-2.5 rounded-full bg-jaguar-400 shrink-0"></span>
              {tag}
