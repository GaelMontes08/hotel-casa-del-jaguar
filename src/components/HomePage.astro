          ))}
        </div>

        <!-- Bottom: Google reviews badge -->
        <a
          href={REVIEWS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="ts-reveal absolute bottom-6 right-6 flex items-center gap-3 px-4 py-3 rounded-2xl backdrop-blur-md border border-white/15 hover:border-white/30 transition-all duration-300"
          style="background:rgba(10,16,12,0.65); --td:380ms"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" class="shrink-0">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          <div>
            <div class="flex gap-0.5 mb-0.5">
              {Array.from({length:5}).map(() => (
                <svg class="w-3 h-3 text-jaguar-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <p class="text-white/60 text-[0.6rem] tracking-wide">Google Reviews</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ── CTA banner ── -->
  <section class="py-24 px-4 bg-jungle-950">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-[0.62rem] uppercase tracking-[0.3em] text-jaguar-500 mb-5">{t.booking.title}</p>
      <h2 class="font-heading text-3xl sm:text-4xl font-semibold text-white mb-4">
        {t.booking.subtitle}
      </h2>
      <p class="text-jungle-400 text-sm mb-10 font-light">{t.booking.body}</p>
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-10 py-4 rounded-full bg-jaguar-500 text-white font-medium tracking-widest uppercase text-xs hover:bg-jaguar-400 transition-colors duration-300 shadow-xl shadow-black/30"
      >
        {t.booking.cta}
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </section>



</Layout>

<style>
  /* ── About section: fade-in columns ── */
  .home-fade-col {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s ease var(--delay, 0ms), transform 0.7s ease var(--delay, 0ms);
  }
  .home-fade-col.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── About section: stacked cards hover ── */
  .home-card-stack:hover .hcard-3 { transform: rotate(8deg) translate(20px, 10px); }
  .home-card-stack:hover .hcard-2 { transform: rotate(4deg) translate(10px, 5px); }
  .home-card-stack:hover .hcard-1 { transform: rotate(-1deg) scale(1.02); box-shadow: 0 32px 64px rgba(0,0,0,0.22); }

  .hcard { transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.5s ease; }

  /* ── Connect icons ── */
  .home-connect-icon { transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease; }
  .home-connect-icon:hover { transform: translateY(-2px); }

  /* ── Testimonials: reveal ── */
  .ts-reveal {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.75s ease var(--td, 0ms), transform 0.75s ease var(--td, 0ms);
  }
  .ts-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Thumbnail active ring */
  .ts-thumb { transition: ring 0.2s; }

  /* ── Story section: generic reveal ── */
  .story-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease var(--sd, 0ms), transform 0.8s ease var(--sd, 0ms);
  }
  .story-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Story section: line-mask slide-up per word ── */
  .story-word {
    transform: translateY(110%);
    transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1) var(--sd, 80ms);
  }
  .story-reveal.visible .story-word {
    transform: translateY(0);
  }
</style>

<script>
  // Subtle parallax on scroll
  const heroBg = document.getElementById('hero-bg');
  if (heroBg && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const onScroll = () => {
      const y = window.scrollY;
      if (y < window.innerHeight) {
        heroBg.style.transform = `translateY(${y * 0.25}px)`;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Fade-in columns in the About section
  const cols = document.querySelectorAll<HTMLElement>('.home-fade-col');
  const observer = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('visible');
        observer.unobserve(e.target);
      }
    }),
    { threshold: 0.15 }
  );
  cols.forEach((el) => observer.observe(el));

  // Story section reveals
  const reveals = document.querySelectorAll<HTMLElement>('.story-reveal');
  const storyObs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('visible');
        storyObs.unobserve(e.target);
      }
    }),
    { threshold: 0.2 }
  );
  reveals.forEach((el) => storyObs.observe(el));

  // Testimonials reveals
  const tsReveals = document.querySelectorAll<HTMLElement>('.ts-reveal');
  const tsObs = new IntersectionObserver(
    (entries) => entries.forEach((e) => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('visible');
        tsObs.unobserve(e.target);
      }
    }),
    { threshold: 0.15 }
  );
  tsReveals.forEach((el) => tsObs.observe(el));

  // Testimonials image subtle parallax
  const tsImg = document.getElementById('ts-img-wrap');
  if (tsImg && window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    const onScroll = () => {
      const rect = tsImg.closest('section')!.getBoundingClientRect();
      const progress = -rect.top / (window.innerHeight + rect.height);
      if (progress > -0.2 && progress < 1.2) {
        tsImg.style.transform = `scale(1.06) translateY(${progress * 30}px)`;
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Mobile menu toggle
</script>
