---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = useTranslations(locale);
---

<Layout locale={locale} title={t.contact.title} canonicalPath={path}>
  <section class="relative h-56 flex items-center justify-center bg-jungle-900 overflow-hidden">
    <div class="text-center text-white">
      <h1 class="font-heading text-4xl font-bold">{t.contact.title}</h1>
      <p class="mt-2 text-jungle-300">{t.contact.subtitle}</p>
    </div>
  </section>

  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">
      <!-- Contact info -->
      <div>
        <dl class="space-y-6 text-stone-600">
          <div>
            <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">{t.contact.email}</dt>
            <dd><a href="mailto:info@hotelcasadeljaguar.com" class="hover:text-jaguar-600 transition-colors">info@hotelcasadeljaguar.com</a></dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">{t.contact.phone}</dt>
            <dd><a href="tel:+51000000000" class="hover:text-jaguar-600 transition-colors">+51 (0) 000 000 000</a></dd>
          </div>
          <div>
            <dt class="text-xs uppercase tracking-widest text-stone-400 mb-1">{t.contact.address}</dt>
            <dd>Iquitos, Loreto, Perú</dd>
          </div>
        </dl>
      </div>

      <!-- Contact form -->
      <form
        class="space-y-4"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
        novalidate
      >
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1" for="name">
            {t.contact.namePlaceholder}
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder={t.contact.namePlaceholder}
            class="w-full rounded-lg border border-stone-200 px-4 py-2.5 text-stone-700 placeholder-stone-300 focus:outline-none focus:ring-2 focus:ring-jaguar-400"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1" for="email">
            {t.contact.emailPlaceholder}
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder={t.contact.emailPlaceholder}
            class="w-full rounded-lg border border-stone-200 px-4 py-2.5 text-stone-700 placeholder-stone-300 focus:outline-none focus:ring-2 focus:ring-jaguar-400"
          />
        </div>
        <div>
          <label class="block text-sm font-medium text-stone-700 mb-1" for="message">
            {t.contact.messagePlaceholder}
          </label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            placeholder={t.contact.messagePlaceholder}
            class="w-full rounded-lg border border-stone-200 px-4 py-2.5 text-stone-700 placeholder-stone-300 focus:outline-none focus:ring-2 focus:ring-jaguar-400 resize-none"
          ></textarea>
        </div>
        <input type="hidden" name="_language" value={locale} />
        <button
          type="submit"
          class="w-full py-3 rounded-full bg-jaguar-600 text-white font-semibold hover:bg-jaguar-700 transition-colors"
        >
          {t.contact.send}
        </button>
      </form>
    </div>
  </section>
</Layout>
