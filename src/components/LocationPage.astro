---
import Layout from '@/layouts/Layout.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n/utils';

interface Props {
  locale: Locale;
  path: string;
}
const { locale, path } = Astro.props;
const t = useTranslations(locale);
---

<Layout locale={locale} title={t.location.title} canonicalPath={path}>
  <section class="relative h-56 flex items-center justify-center bg-jungle-900 overflow-hidden">
    <div class="text-center text-white">
      <h1 class="font-heading text-4xl font-bold">{t.location.title}</h1>
      <p class="mt-2 text-jungle-300">{t.location.subtitle}</p>
    </div>
  </section>

  <section class="py-16 px-4 bg-white">
    <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-10 items-start">
      <div>
        <h2 class="font-heading text-2xl font-bold text-jungle-800 mb-4">{t.location.directions}</h2>
        <p class="text-stone-500 mb-6">{t.location.directionsBody}</p>
        <p class="font-medium text-stone-700">{t.location.address}</p>
      </div>
      <!-- Embedded map placeholder -->
      <div class="rounded-2xl overflow-hidden aspect-video bg-stone-100 flex items-center justify-center text-stone-400">
        <iframe
          title="Hotel Casa del Jaguar — Mapa"
          class="w-full h-full border-0"
          loading="lazy"
          allowfullscreen
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d255282.47569697737!2d-73.49186!3d-3.74912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91ea10de4e6e4af1%3A0x4f4fa574a2a87a49!2sIquitos%2C%20Peru!5e0!3m2!1sen!2s!4v1680000000000"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>
