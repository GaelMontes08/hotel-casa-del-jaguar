---
import SiteNav from '@/components/SiteNav.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n/utils';
import '@/styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  /** Canonical path (without locale prefix), e.g. '/' or '/habitaciones' */
  canonicalPath?: string;
}

const { locale, title, description, canonicalPath = '/' } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ? `${title} — ${t.seo.siteName}` : t.seo.siteName;
const pageDescription = description ?? t.seo.defaultDescription;

const altLang = locale === 'es' ? 'en' : 'es';
const altPath = altLang === 'es' ? canonicalPath : `/en${canonicalPath}`;
const canonicalHref = `https://hotelcasadeljaguar.com${locale === 'es' ? canonicalPath : `/en${canonicalPath}`}`;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/cj-icon-dark.webp" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/cj-icon-light.webp" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="es" href={`https://hotelcasadeljaguar.com${canonicalPath}`} />
    <link rel="alternate" hreflang="en" href={`https://hotelcasadeljaguar.com/en${canonicalPath}`} />
    <link rel="alternate" hreflang="x-default" href={`https://hotelcasadeljaguar.com${canonicalPath}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:site_name" content={t.seo.siteName} />
    <meta property="og:image" content="https://hotelcasadeljaguar.com/og-image.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>
  </head>
  <body class="bg-[#faf8f4] text-stone-800 font-body antialiased">
    <SiteNav locale={locale} canonicalPath={canonicalPath} overlay={canonicalPath === '/'} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- Floating WhatsApp button -->
    <a
      href="https://wa.me/51917811803"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:scale-110 active:scale-95 transition-transform duration-200"
      style="background:#25D366"
    >
      <svg width="28" height="28" viewBox="0 0 24 24" fill="white" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
    </a>
  </body>
</html>
