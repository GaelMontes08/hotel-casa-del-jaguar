---
import SiteNav from '@/components/SiteNav.astro';
import Footer from '@/components/Footer.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n/utils';
import '@/styles/global.css';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  /** Canonical path (without locale prefix), e.g. '/' or '/habitaciones' */
  canonicalPath?: string;
}

const { locale, title, description, canonicalPath = '/' } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ? `${title} — ${t.seo.siteName}` : t.seo.siteName;
const pageDescription = description ?? t.seo.defaultDescription;

const altLang = locale === 'es' ? 'en' : 'es';
const altPath = altLang === 'es' ? canonicalPath : `/en${canonicalPath}`;
const canonicalHref = `https://hotelcasadeljaguar.com${locale === 'es' ? canonicalPath : `/en${canonicalPath}`}`;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/cj-icon-dark.webp" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/cj-icon-light.webp" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical & hreflang -->
    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="es" href={`https://hotelcasadeljaguar.com${canonicalPath}`} />
    <link rel="alternate" hreflang="en" href={`https://hotelcasadeljaguar.com/en${canonicalPath}`} />
    <link rel="alternate" hreflang="x-default" href={`https://hotelcasadeljaguar.com${canonicalPath}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:site_name" content={t.seo.siteName} />
    <meta property="og:image" content="https://hotelcasadeljaguar.com/og-image.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <title>{pageTitle}</title>
  </head>
  <body class="bg-[#faf8f4] text-stone-800 font-body antialiased">
    <SiteNav locale={locale} canonicalPath={canonicalPath} overlay={canonicalPath === '/'} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
